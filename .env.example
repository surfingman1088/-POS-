APP_NAME=MVS
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost

APP_LOCALE=zh
APP_FALLBACK_LOCALE=zh
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=MVS_DB
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# STORE CONFIG

# Store name config
STORE_NAME="STORE NAME"
STORE_NAME_ALT="STORE ALT NAME"
STORE_ADDRESS="STORE ADDRESS"

# Store Default Order Type [walk_in, deliver]
STORE_DEFAULT_ORDER_TYPE="deliver"

# default payment type [cash, gcash]
STORE_DEFAULT_PAYMENT_TYPE="cash"

# editlock orders status config [pending, preparing, in_transit, delivered, completed, cancelled]
ORDER_EDIT_LOCK_STATUS="preparing,in_transit,delivered"

# Store hours config
STORE_OPEN_HOUR=7
STORE_CLOSE_HOUR=20

# Store open days config (1-7 where 1=Monday, 7=Sunday)
STORE_OPEN_DAYS="1,2,3,4,5,6"

# Store payment type, add more other payment types as needed separated by commas (e.g. cash,gcash,maya,BPI)
# cash is added by default
OTHER_PAYMENT_TYPES="gcash,maya,BPI"

# Account session expire duration in days
SESSION_EXPIRE_DAYS=30
